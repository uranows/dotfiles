{
    "layer": "top",
    "position": "top",
    "height": 28,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "network", "bluetooth", "tray", "clock"],
    "hyprland/workspaces": {
        "format": "{name}"
    },
    "hyprland/window": {
        "format": "{}"
    },
    "cpu": {
        "format": "{}%"
    },
    "memory": {
        "format": "{}%"
    },
    "network": {
        "format-wifi": "{signalStrength}%",
        "format-ethernet": "E",
        "format-disconnected": "N/A"
    },
    "bluetooth": {
        "format": "{}",
        "format-connected": "{num_connections}"
    },
    "clock": {
        "format": "{:%H:%M %d/%m}"
    }
}
