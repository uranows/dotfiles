# Source: home/dot_config/chezmoi/chezmoi.toml.tmpl
# Target: ~/.config/chezmoi/chezmoi.toml

# --- Windows Specific Mappings ---
{{ if eq .chezmoi.os "windows" -}}

# Map PowerShell Profile from apps/ directory
# Target path is relative to the user's home directory
["Documents/PowerShell/Microsoft.PowerShell_profile.ps1"]
    source = "apps/powershell/Microsoft.PowerShell_profile.ps1"
    type = "file" # Can be file or template

# Windows Terminal mapping removed - handled by run_once script

{{ end -}}

# --- OS-Specific Script Mappings ---
# These scripts will be automatically selected based on OS detection

# Windows package installation
{{ if eq .chezmoi.os "windows" -}}
["scripts/install-packages.windows.ps1"]
    source = "scripts/install-packages.windows.ps1"
    type = "run_once"
    condition = "windows"

{{ else if eq .chezmoi.os "linux" -}}

# Check if generic mode is forced via environment variable
{{ if (getenv "CHEZMOI_FORCE_GENERIC") -}}
# Force generic Linux configuration
["scripts/install-packages.linux-generic.sh"]
    source = "scripts/install-packages.linux-generic.sh"
    type = "run_once"
    condition = "linux"

{{ else -}}
# Detect Linux distribution for package manager selection
{{ $distro := "unknown" }}
{{ if (stat "/etc/arch-release") }}
    {{ $distro = "arch" }}
{{ else if (stat "/etc/debian_version") }}
    {{ $distro = "debian" }}
{{ else if (stat "/etc/redhat-release") }}
    {{ $distro = "redhat" }}
{{ end }}

# Arch Linux systems (specific package manager)
{{ if eq $distro "arch" -}}
["scripts/install-packages.linux-arch.sh"]
    source = "scripts/install-packages.linux-arch.sh"
    type = "run_once"
    condition = "linux && arch"

{{ else -}}
# Debian-based systems and generic Linux fallback
# This covers: Ubuntu, Debian, Mint, Pop!_OS, and other apt-based distros
["scripts/install-packages.linux-generic.sh"]
    source = "scripts/install-packages.linux-generic.sh"
    type = "run_once"
    condition = "linux"

{{ end -}}
{{ end -}}
{{ end -}}

# --- Interpreters ---
# Explicitly tell chezmoi how to run scripts on different platforms
[interpreters]
  # Match standard .ps1 files on Windows
  [interpreters.ps1]
    command = "powershell.exe"
    args = ["-NoProfile", "-NoLogo", "-ExecutionPolicy", "Bypass", "-File"]

  # Run .sh scripts via WSL bash.exe on Windows (requires WSL)
  [interpreters.sh]
    command = "bash.exe"
    args = ["-eu", "-o", "pipefail"]

# --- General chezmoi settings can go here ---
