{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.0.0/resources/zpack-schema.json",
  "name": "local.right-bar",
  "version": "1.0.0",
  "description": "Vertical right-side bar with komorebi integration and systray",
  "widgets": [
    {
      "name": "bar",
      "htmlPath": "./index.html",
      "includeFiles": ["*.html", "*.css"],
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "privileges": {
        "shellCommands": [
          { "program": "powershell", "argsRegex": ".*" }
        ]
      },
      "presets": [
        {
          "name": "bottom-ultrawide",
          "anchor": "top_right",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "64px",
          "height": "100%",
          "monitorSelection": { "type": "index", "match": 0 },
          "dockToEdge": { "enabled": true, "edge": "right", "windowMargin": "0px" }
        },
        {
          "name": "top-ultrawide",
          "anchor": "top_right",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "48px",
          "height": "100%",
          "monitorSelection": { "type": "index", "match": 1 },
          "dockToEdge": { "enabled": true, "edge": "right", "windowMargin": "0px" }
        },
        {
          "name": "laptop",
          "anchor": "top_right",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "40px",
          "height": "100%",
          "monitorSelection": { "type": "index", "match": 2 },
          "dockToEdge": { "enabled": true, "edge": "right", "windowMargin": "0px" }
        }
      ]
    }
  ]
}
